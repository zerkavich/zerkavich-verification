# Токен бота от @BotFather
BOT_TOKEN=1234567890:AAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAAA

# Pterodactyl API
PTERODACTYL_URL=https://my.aurorix.net
PTERODACTYL_KEY=ВАШ_КЛЮЧ_СЮДА
SERVER_ID=6daf8160-16ab-4a5b-ac25-3e35cb75a3d4

# Путь к pfids.json на сервере (пишется pfid_bridge.py)
# Pterodactyl обычно: /home/container/pfids.json
PFIDS_PATH=/home/container/pfids.json

# Telegram канал сервера
TG_CHANNEL=@zerkavich

# Проверять подписку перед верификацией? (true/false)
CHECK_SUBSCRIPTION=false

# TG ID администраторов через запятую (узнать свой: @userinfobot)
ADMIN_TG_IDS=123456789,987654321

# Куда отправлять за обжалованием бана
APPEAL_URL=@zerkavich
